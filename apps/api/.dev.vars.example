# Copy to .dev.vars (gitignored) and fill in your values.
# Used by `wrangler dev` for local secrets — equivalent to `wrangler secret put` for production.

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ADMIN_JWT_SECRET=
INTERNAL_API_SECRET=

ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_ENCRYPTION_KEY=

P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC_KEY=
P24_API_KEY=
