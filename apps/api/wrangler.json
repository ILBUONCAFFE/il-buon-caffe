{
	"name": "il-buon-caffe-api",
	"main": "src/index.ts",
	"compatibility_date": "2025-09-01",
	"compatibility_flags": ["nodejs_compat"],
	"limits": { "cpu_ms": 30000 },
	"observability": {
		"enabled": true
	},
	"r2_buckets": [
		{
			"binding": "IMAGES_BUCKET",
			"bucket_name": "il-buon-caffe-images",
			"preview_bucket_name": "il-buon-caffe-images-dev"
		},
		{
			"binding": "CATALOGS_BUCKET",
			"bucket_name": "il-buon-caffe-catalogs",
			"preview_bucket_name": "il-buon-caffe-catalogs-dev"
		},
		{
			"binding": "MEDIA_BUCKET",
			"bucket_name": "il-buon-caffe-media",
			"preview_bucket_name": "il-buon-caffe-media-dev"
		}
	],
	"d1_databases": [
		{
			"binding": "CONTENT_DB",
			"database_name": "il-buon-caffe-content",
			"database_id": "18dbaa4f-5bc4-41f2-861f-7de55c30deb2"
		}
	],
	"kv_namespaces": [
		{
			"binding": "ALLEGRO_KV",
			"id": "2dbf90378fb8442fb5f32b63251cd27a",
			"preview_id": "d6770812f0f54e248fdfa607b8732542"
		}
	],
	"triggers": {
		"crons": [
			"0 * * * *",
			"0 */2 * * *",
			"*/6 * * * *",
			"*/10 * * * *",
			"0 3 * * *"
		]
	},
	"vars": {
		"NODE_ENV": "production",
		"MEDIA_PUBLIC_URL": "https://media.ilbuoncaffe.pl",
		"ALLEGRO_ENVIRONMENT": "production",
		"ALLEGRO_REDIRECT_URI": "https://api.ilbuoncaffe.pl/api/admin/allegro/callback",
		"ALLEGRO_ADMIN_REDIRECT_URL": "https://ilbuoncaffe.pl/admin/settings",
		"PUBLIC_URL": "https://api.ilbuoncaffe.pl",
		"FRONTEND_URL": "https://ilbuoncaffe.pl",
		"P24_SANDBOX": "false"
	},
	"unsafe": {
		"bindings": [
			{ "type": "ratelimit", "name": "RL_API",            "namespace_id": "1001", "simple": { "limit": 100, "period": 60   } },
			{ "type": "ratelimit", "name": "RL_ADMIN",          "namespace_id": "1002", "simple": { "limit": 300, "period": 60   } },
			{ "type": "ratelimit", "name": "RL_LOGIN",          "namespace_id": "1003", "simple": { "limit": 5,   "period": 60 } },
			{ "type": "ratelimit", "name": "RL_REGISTER",       "namespace_id": "1004", "simple": { "limit": 3,   "period": 60 } },
			{ "type": "ratelimit", "name": "RL_PASSWORD_RESET", "namespace_id": "1005", "simple": { "limit": 3,   "period": 60 } },
			{ "type": "ratelimit", "name": "RL_HEALTH",         "namespace_id": "1006", "simple": { "limit": 20,  "period": 60 } },
			{ "type": "ratelimit", "name": "RL_USER_EXPORT",    "namespace_id": "1007", "simple": { "limit": 5,   "period": 60 } }
		]
	}
}
