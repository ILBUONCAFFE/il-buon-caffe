);transform:translateY(20px)\">której<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">zaufasz<!-- --> </span></span></span></h2></div><div class=\"flex flex-col justify-end\"><div class=\"origin-left h-[1px] bg-gradient-to-r from-brand-400/50 to-transparent mb-8 hidden lg:block\" style=\"transform:scaleX(0)\"></div><p class=\"text-white/50 text-lg md:text-xl leading-relaxed max-w-xl\"><span class=\"sr-only\">Od 2003 roku tworzymy miejsce, gdzie spotyka się rzemiosło z pasją. Każdy produkt w naszym sklepie jest dowodem na to, że jakość i smak mogą iść w parze.</span><span aria-hidden=\"true\" class=\"inline-block\"><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">Od<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">2003<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">roku<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">tworzymy<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">miejsce,<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">gdzie<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">spotyka<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">się<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">rzemiosło<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">z<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">pasją.<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">Każdy<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">produkt<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">w<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">naszym<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">sklepie<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">jest<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">dowodem<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">na<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">to,<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">że<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">jakość<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">i<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">smak<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">mogą<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">iść<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">w<!-- --> </span></span><span class=\"inline-block overflow-hidden\"><span class=\"inline-block\" style=\"opacity:0;clip-path:inset(100% 0 0 0);transform:translateY(20px)\">parze.<!-- --> </span></span></span></p></div></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6\"><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">150+</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\">zł</span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Darmowa dostawa</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-truck w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2\"></path><path d=\"M15 18H9\"></path><path d=\"M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14\"></path><circle cx=\"17\" cy=\"18\" r=\"2\"></circle><circle cx=\"7\" cy=\"18\" r=\"2\"></circle></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Przy zamówieniach powyżej 150 zł wysyłka jest zawsze gratis.</p></div></div><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">100</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\">%</span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Gwarancja jakości</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Każdy produkt przechodzi rygorystyczną selekcję smaku.</p></div></div><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">20</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\">+</span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Doświadczenie</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Od ponad dwóch dekad budujemy markę, której ufają tysiące.</p></div></div><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">24</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\">h</span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Szybka wysyłka</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"M12 6v6l4 2\"></path><circle cx=\"12\" cy=\"12\" r=\"10\"></circle></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Realizujemy zamówienia w ciągu jednego dnia roboczego.</p></div></div><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">100</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\">%</span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Świeżość</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-leaf w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z\"></path><path d=\"M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12\"></path></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Kawa palona na zamówienie — nigdy nie czeka na półce.</p></div></div><div class=\"group relative\" style=\"opacity:0;transform:translateY(60px)\"><div class=\"relative h-full rounded-2xl bg-white/[0.04] border border-white/[0.08] backdrop-blur-sm p-8 md:p-10 hover:bg-white/[0.08] hover:border-white/[0.15] transition-all duration-700\"><div class=\"flex items-baseline gap-1 mb-6\"><span class=\"text-5xl md:text-6xl font-serif text-white leading-none tracking-tight\">∞</span><span class=\"text-2xl md:text-3xl font-serif text-brand-400 italic leading-none\"></span></div><div class=\"w-8 h-[1px] bg-white/20 mb-6 group-hover:w-full transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]\"></div><div class=\"flex items-start justify-between gap-4 mb-3\"><h3 class=\"text-lg md:text-xl font-semibold text-white/90 leading-snug\">Pasja</h3><div class=\"flex-shrink-0 w-10 h-10 rounded-full bg-white/[0.06] border border-white/[0.1] flex items-center justify-center group-hover:bg-brand-400/20 group-hover:border-brand-400/30 transition-all duration-500\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-heart w-[18px] h-[18px] text-brand-400/80 group-hover:text-brand-400 transition-colors duration-500\" aria-hidden=\"true\"><path d=\"M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5\"></path></svg></div></div><p class=\"text-sm text-white/40 leading-relaxed group-hover:text-white/60 transition-colors duration-500\">Za każdym produktem stoi człowiek zakochany w rzemiośle.</p></div></div></div><div class=\"text-center mt-20 md:mt-28\" style=\"opacity:0;transform:translateY(20px)\"><p class=\"text-white/20 text-xs uppercase tracking-[0.25em]\">Dołącz do tysięcy zadowolonych klientów</p></div></div></section><section class=\"relative py-24 md:py-32 min-h-screen flex flex-col justify-center bg-brand-900 overflow-hidden\"><div class=\"absolute inset-0 z-0\" style=\"transform:translateY(100px)\"><img alt=\"Przytulne wnętrze kawiarni Il Buon Caffe w Koszalinie\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover opacity-30\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.unsplash.com%2Fphoto-1501339847302-ac426a4a7cbb%3Fq%3D80%26w%3D2000%26auto%3Dformat%26fit%3Dcrop&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.unsplas