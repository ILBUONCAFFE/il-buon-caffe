{
	"name": "il-buon-caffe-web",
	"compatibility_date": "2025-09-01",
	"compatibility_flags": ["nodejs_compat"],
	"limits": { "cpu_ms": 30000 },
	"main": ".open-next/worker.js",
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			"binding": "API_WORKER",
			"service": "il-buon-caffe-api"
		}
	],
	"kv_namespaces": [
		{
			"binding": "NEXT_INC_CACHE",
			"id": "e58cf9cd0545485a99bc94d2e5bc7edc"
		}
	],
	"vars": {
		"INTERNAL_API_URL": "https://api.ilbuoncaffe.pl",
		"NEXT_PUBLIC_API_URL": "https://api.ilbuoncaffe.pl",
		"NEXT_PUBLIC_SITE_URL": "https://ilbuoncaffe.pl",
		"NEXT_PUBLIC_R2_MEDIA_URL": "https://media.ilbuoncaffe.pl",
		"NEXT_PUBLIC_CLARITY_PROJECT_ID": "w8jxvqums4",
		"BREVO_LIST_IDS": "11,13"
	}
}
