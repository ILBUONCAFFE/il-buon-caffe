{
  "name": "il-buon-caffe-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "shipments:backfill:dry": "node packages/db/scripts/backfill-shipment-consistency.cjs",
    "shipments:backfill:apply": "node packages/db/scripts/backfill-shipment-consistency.cjs --apply",
    "seo:monitor": "node scripts/seo-monitoring-check.mjs --base-url=https://ilbuoncaffe.pl",
    "seo:monitor:strict": "node scripts/seo-monitoring-check.mjs --base-url=https://ilbuoncaffe.pl --strict",
    "media:generate": "node scripts/generate-placeholder-images.js",
    "media:upload": "bash scripts/upload-r2-media.sh il-buon-caffe-media-dev",
    "media:upload:prod": "bash scripts/upload-r2-media.sh il-buon-caffe-media"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.31.8",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "latest"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@aws-sdk/xml-builder": {
      "fast-xml-parser": "5.5.8"
    }
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1"
  }
}
